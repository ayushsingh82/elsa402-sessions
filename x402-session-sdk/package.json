{
  "name": "elsax402-sessions",
  "version": "0.1.0",
  "description": "Sign once, settle many times — session-based x402 payments on Base (EVM). One on-chain ERC20 approve unlocks unlimited micropayments via transferFrom until the cap or expiry is reached. No per-request wallet popup. Powered by USDC on Base Sepolia.",
  "license": "MIT",
  "author": "elsa",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./scheme": {
      "types": "./dist/scheme-server.d.ts",
      "default": "./dist/scheme-server.js"
    },
    "./evm": {
      "types": "./dist/evm.d.ts",
      "default": "./dist/evm.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "x402",
    "elsa",
    "base",
    "base-sepolia",
    "evm",
    "usdc",
    "payments",
    "micropayments",
    "session",
    "pay-per-call",
    "viem",
    "sign-once",
    "settle-many",
    "agentic-payments"
  ],
  "peerDependencies": {
    "viem": "^2.21.0",
    "@x402/core": "^2.8.0"
  },
  "peerDependenciesMeta": {
    "@x402/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22",
    "@x402/core": "^2.8.0",
    "typescript": "^5.5.0",
    "viem": "^2.21.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
