# elsax402-sessions facilitator configuration

# HTTP server
PORT=4021

# Network identifiers (advertised in /supported)
NETWORK=base:sepolia
NETWORK_CAIP=eip155:84532
CHAIN_ID=84532

# RPC endpoint (Base Sepolia public, Alchemy, Infura, QuickNode, …)
BASE_RPC_URL=https://sepolia.base.org

# Facilitator signing key (this account pays gas and is the `spender` in approve/transferFrom).
# Must be funded with Base Sepolia ETH.
# Faucet: https://www.alchemy.com/faucets/base-sepolia
FACILITATOR_PRIVATE_KEY=0xYOUR_64_HEX_PRIVATE_KEY_HERE

# USDC contract address on Base Sepolia (Circle FiatTokenProxy v2)
USDC_CONTRACT_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Decimals for the asset (USDC on Base = 6)
ASSET_DECIMALS=6

# Max per-call price in decimal units (policy limit; /settle refuses amounts above this)
MAX_PER_CALL=1.00

# SQLite path
DB_PATH=./sessions.db
